# ------------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------

# The name of your application. Used in emails, notifications, and page headers.
APP_NAME="Logger Backend"

# The application environment.
# Options:
#   - local       : For local development and debugging.
#   - testing     : For running automated unit/feature tests.
#   - production  : For live server deployments. Turn off debugging here!
APP_ENV=local

# Application Encryption Key. Used for session encryption and password hashes.
# Can be generated automatically using: php artisan key:generate --force
APP_KEY=

# Enable or disable detailed error pages and debug messages.
# Options:
#   - true  : Show details (useful for local development).
#   - false : Hide details and show generic 500 error pages (MUST be false in production for security).
APP_DEBUG=true

# The public URL of the application. Used for generating links in emails or API.
# Examples:
#   - http://localhost:8080 (default for Docker local environment)
#   - https://logger.yourdomain.com (for production with SSL)
APP_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# DOCKER HOST PORT BINDINGS
# ------------------------------------------------------------------------------
# These variables control the ports exposed on your host machine under Docker.

# Port to access the Laravel web application dashboard and API from your browser/host.
# Options: Any free port on your host (default is 8080).
APP_PORT=8080

# Port to access the PostgreSQL database directly from your host.
# Options: Any free port on your host (default is 5432).
DB_PORT=5432

# Port to access the Adminer database management web panel.
# Options: Any free port on your host (default is 800).
ADMINER_PORT=800

# ------------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ------------------------------------------------------------------------------

# The logging channel Laravel will use to write logs.
# Options:
#   - stack  : Combine multiple channels (default, logs to daily file).
#   - single : A single laravel.log file.
#   - daily  : Rotating logs daily (creates separate files for each day).
#   - syslog : System logger.
LOG_CHANNEL=stack

# The minimum severity level to log.
# Options: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# DATABASE CONNECTION (Laravel Internal)
# ------------------------------------------------------------------------------
# These parameters are used by Laravel to connect to PostgreSQL.
# In a Docker setup, these MUST align with the database configuration in db.env.

# The database connection driver. Must be 'pgsql' for PostgreSQL.
DB_CONNECTION=pgsql

# The hostname of the database server.
# Options:
#   - db        : Within the Docker network, use the name of the database service 'db'.
#   - 127.0.0.1 : If running Laravel outside Docker connecting to a local DB.
DB_HOST=db

# The port PostgreSQL listens to inside the container. Do not change this unless postgres.conf is modified.
DB_PORT=5432

# The name of the database. Must match POSTGRES_DB in db.env.
DB_DATABASE=logger_db

# The database username. Must match POSTGRES_USER in db.env.
DB_USERNAME=user

# The database password. Must match POSTGRES_PASSWORD in db.env.
DB_PASSWORD=password

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------------------------

# Secret key used to sign and verify JWT tokens for the client API (WinForms).
# Can be generated automatically using: php artisan jwt:secret --force
JWT_SECRET=

# ------------------------------------------------------------------------------
# API DOCUMENTATION (Swagger)
# ------------------------------------------------------------------------------

# Enable automatic regeneration of Swagger (OpenAPI) docs on every request.
# Options:
#   - true  : Auto-regenerate docs (useful in local dev).
#   - false : Read static generated JSON docs (recommended in production to save CPU).
L5_SWAGGER_GENERATE_ALWAYS=true

# ------------------------------------------------------------------------------
# DRIVERS AND SESSIONS
# ------------------------------------------------------------------------------

# Storage driver for user sessions.
# Options:
#   - database : Save sessions in the DB (default, works great for clustered setups).
#   - file     : Standard file-based sessions in storage/framework/sessions.
#   - redis    : Fast memory-cache store (requires Redis setup).
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Storage driver for cache caching.
# Options: database, file, redis, memcached
CACHE_STORE=database

# The disk for storing user-uploaded files.
# Options: local (storage/app), public (storage/app/public), s3 (Amazon AWS)
FILESYSTEM_DISK=local

# Queue system driver.
# Options: sync (run immediately), database (async via DB queue table), redis, sqs
QUEUE_CONNECTION=database

# ------------------------------------------------------------------------------
# EXTERNAL SERVICES (Optional Configuration)
# ------------------------------------------------------------------------------

# Memcached Cache Server Host
MEMCACHED_HOST=127.0.0.1

# Redis Server Connection Settings
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (For password reset or system mail)
# Options for MAIL_MAILER:
#   - log  : Write all emails to storage/logs/laravel.log (default for testing/dev).
#   - smtp : Send actual emails via an external SMTP server.
#   - mailgun, ses, postmark : API-based mail delivery.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Amazon AWS Storage Settings (Used if FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
