# ------------------------------------------------------------------------------
# POSTGRESQL CONTAINER CONFIGURATION
# ------------------------------------------------------------------------------
# These variables configure the PostgreSQL database container upon its first initialization.
# Note: Changing these after the database volume has been initialized has no effect.

# The master database administrator username.
POSTGRES_USER=user

# The master database administrator password.
POSTGRES_PASSWORD=password

# The name of the default database created upon container initialization.
POSTGRES_DB=logger_db

# ------------------------------------------------------------------------------
# AUTOMATIC INITIAL ADMINISTRATOR SEEDING
# ------------------------------------------------------------------------------
# These parameters define the first administrative user created in the application database
# by the DatabaseSeeder class during the container's entrypoint initialization.
# IMPORTANT: Ensure config caching retrieves these correctly. Do not use env() outside config.

# The display name for the auto-seeded administrative user.
ADMIN_NAME=Admin

# The login email address for the administrator dashboard access.
ADMIN_EMAIL=admin@example.com

# The password for the administrative user (must be at least 8 characters long).
ADMIN_PASSWORD=password
